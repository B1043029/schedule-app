//  SHIFTS
// ════════════════════════════════════════
function renderShifts() {
  const preset = storeShifts().filter(s => s.preset);
  const custom = storeShifts().filter(s => !s.preset);
  document.getElementById('shiftTableBody').innerHTML = preset.map(s => shiftRow(s, false)).join('');
  document.getElementById('customShiftBody').innerHTML = custom.length
    ? custom.map(s => shiftRow(s, true)).join('')
    : '<tr><td colspan="8" style="color:var(--text2);font-size:12px;padding:12px 10px;">尚未新增自訂班別</td></tr>';
}
function shiftRow(s, showDelete) {
  return `<tr>
    <td><span class="shift-dot ${dotClass[s.period]||'dot-morning'}"></span>
      <input class="inline-input inline-input-name" value="${s.name}" onchange="updateShift(${s.id},'name',this.value)"></td>
    <td><input class="inline-input" value="${s.start}" onchange="updateShift(${s.id},'start',this.value)"></td>
    <td><input class="inline-input" value="${s.end}"   onchange="updateShift(${s.id},'end',this.value)"></td>
    <td style="font-family:var(--mono);font-size:12px;">${shiftHours(s).toFixed(0)}h</td>
    <td><input class="inline-input inline-input-sm" type="number" value="${s.staff}" min="1" onchange="updateShift(${s.id},'staff',+this.value)"> 人</td>
    <td><select class="inline-input" style="width:70px;" onchange="updateShift(${s.id},'mult',+this.value)">
      <option value="1" ${s.mult===1?'selected':''}>×1.0</option>
      <option value="2" ${s.mult===2?'selected':''}>×2.0</option>
    </select></td>
    <td><div class="toggle ${s.active?'on':'off'}" onclick="toggleShift(${s.id})"></div></td>
    ${showDelete ? `<td><button class="btn btn-ghost btn-sm" onclick="removeCustomShift(${s.id})">刪除</button></td>` : ''}
  </tr>`;
}
function updateShift(id, key, val) { const s=shifts.find(x=>x.id===id); if(s){s[key]=val; renderShifts();} }
function toggleShift(id)           { const s=shifts.find(x=>x.id===id); if(s){s.active=!s.active; renderShifts();} }
function addCustomShift()          { shifts.push({id:sid(),storeId:currentStoreId,name:'自訂班別',type:'weekday',period:'morning',start:'09:00',end:'17:00',staff:1,mult:1.0,active:true,preset:false}); renderShifts(); }
function removeCustomShift(id)     { shifts=shifts.filter(s=>s.id!==id); renderShifts(); }

