      <span style="font-weight:500;">${e.name}</span>
      <span style="color:var(--text2);font-size:11px;flex:1;margin:0 8px;">${e.unavail.length ? e.unavail.map(d=>d.slice(5).replace('-','/')).join(', ') : '未設定'}</span>
      <button class="btn btn-ghost btn-sm" onclick="openUnavailModal(${e.id})">設定</button>
    </div>`).join('');
