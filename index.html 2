<script>
// ════════════════════════════════════════
//  DATA
// ════════════════════════════════════════
const STORE_COLORS = ['#2D5A3D','#1E40AF','#5B21B6','#92400E','#C4472A','#0369A1','#065F46','#7C3AED'];
// Taiwan national holidays by month key "YYYY-MM"
const TW_HOLIDAYS = {
  '2026-01': ['2026-01-01'],
  '2026-02': ['2026-02-16','2026-02-17','2026-02-18','2026-02-19','2026-02-20'],
  '2026-03': [],
  '2026-04': ['2026-04-03','2026-04-04','2026-04-05'],
  '2026-05': ['2026-05-01'],
  '2026-06': ['2026-06-19'],
  '2026-07': ['2026-07-01'],
  '2026-08': [],
  '2026-09': ['2026-09-03'],
  '2026-10': ['2026-10-09','2026-10-10'],
  '2026-11': [],
  '2026-12': ['2026-12-25'],
  '2025-07': ['2025-07-01','2025-07-28'],
};
function getHolidays(year, month) {
  const key = `${year}-${String(month+1).padStart(2,'0')}`;
  return TW_HOLIDAYS[key] || [];
}
function isHoliday(dateStr, holidays) { return holidays.includes(dateStr); }
const cellClass = { morning:'cell-morning', afternoon:'cell-afternoon', evening:'cell-evening', holiday:'cell-holiday' };
const dotClass  = { morning:'dot-morning',  afternoon:'dot-afternoon',  evening:'dot-evening',  holiday:'dot-holiday' };
const AVATAR_PALETTES = [
  ['#E8F0EB','#2D5A3D'],['#EDE9FE','#5B21B6'],['#DBEAFE','#1E40AF'],
  ['#FEF3C7','#92400E'],['#FCE7F3','#9D174D'],['#D1FAE5','#065F46'],
];

function makeDefaultShifts(storeId) {
  return [
    { id: sid(), storeId, name:'平日早班', type:'weekday', period:'morning',   start:'08:00', end:'14:00', staff:2, mult:1.0, active:true,  preset:true },
    { id: sid(), storeId, name:'平日午班', type:'weekday', period:'afternoon', start:'14:00', end:'20:00', staff:2, mult:1.0, active:true,  preset:true },
    { id: sid(), storeId, name:'平日晚班', type:'weekday', period:'evening',   start:'20:00', end:'02:00', staff:1, mult:1.0, active:true,  preset:true },
    { id: sid(), storeId, name:'假日早班', type:'weekend', period:'morning',   start:'08:00', end:'14:00', staff:3, mult:1.0, active:false, preset:true },
    { id: sid(), storeId, name:'假日午班', type:'weekend', period:'afternoon', start:'14:00', end:'20:00', staff:3, mult:1.0, active:true,  preset:true },
    { id: sid(), storeId, name:'國定假日班',type:'holiday', period:'morning',  start:'08:00', end:'14:00', staff:2, mult:2.0, active:true,  preset:true },
  ];
}

let _sid = 100;
function sid() { return ++_sid; }

// Stores array — each store has id, name, address, color
let stores = [
  { id: 1, name: '信義店', address: '台北市信義區松壽路', color: '#2D5A3D' },
  { id: 2, name: '西門店', address: '台北市萬華區西門町', color: '#1E40AF' },
];

// All employees — each has storeId
let employees = [
  { id:10, storeId:1, name:'王小明', rate:175, prefs:['m','a'], minSalaryOn:true,  minSalary:18000, unavail:['2025-07-02','2025-07-09'], avatarBg:'#E8F0EB', avatarColor:'#2D5A3D' },
  { id:11, storeId:1, name:'李美華', rate:180, prefs:['a','e'], minSalaryOn:false, minSalary:0,     unavail:['2025-07-07'],              avatarBg:'#EDE9FE', avatarColor:'#5B21B6' },
  { id:12, storeId:1, name:'陳大偉', rate:160, prefs:['m'],     minSalaryOn:true,  minSalary:15000, unavail:[],                          avatarBg:'#DBEAFE', avatarColor:'#1E40AF' },
  { id:20, storeId:2, name:'林雅婷', rate:170, prefs:['e'],     minSalaryOn:false, minSalary:0,     unavail:['2025-07-05','2025-07-06'], avatarBg:'#FEF3C7', avatarColor:'#92400E' },
  { id:21, storeId:2, name:'張建國', rate:165, prefs:['m','a'], minSalaryOn:true,  minSalary:16000, unavail:[],                          avatarBg:'#D1FAE5', avatarColor:'#065F46' },
];

// All shifts — each has storeId
let shifts = [
  ...makeDefaultShifts(1),
  ...makeDefaultShifts(2),
];

// Schedules: storeId -> { dateStr -> [{shiftId, empId, locked}] }
let schedules = { 1: {}, 2: {} };

// Current active store
let currentStoreId = 1;

// ── Helpers ──
function currentStore()    { return stores.find(s => s.id === currentStoreId); }
function storeEmps()       { return employees.filter(e => e.storeId === currentStoreId); }
function storeShifts()     { return shifts.filter(s => s.storeId === currentStoreId); }
function storeSchedule()   { return schedules[currentStoreId] || {}; }

function shiftHours(s) {
  const [sh,sm] = s.start.split(':').map(Number);
  let [eh,em] = s.end.split(':').map(Number);
  if(eh < sh) eh += 24;
  return (eh + em/60) - (sh + sm/60);
}

function storeBadgeHTML(storeId) {
  const st = stores.find(s => s.id === storeId) || currentStore();
  return `<span style="background:${st.color}22;color:${st.color};padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;">${st.name}</span>`;
}

// ════════════════════════════════════════
//  SCREEN NAV
// ════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  const navEl = document.getElementById('nav-' + name);
  if(navEl) navEl.classList.add('active');
  if(name === 'stores')    renderStores();
  if(name === 'employees') { updateBadges(); renderEmployees(); }
  if(name === 'shifts')    { updateBadges(); renderShifts(); }
  if(name === 'config')    { updateBadges(); renderConfigShiftList(); renderUnavailList(); }
  if(name === 'schedule')  { updateBadges(); updatePeriodLabels(); renderSchedule(); }
  if(name === 'summary')   { updateBadges(); updatePeriodLabels(); renderSummary(); }
}

function updatePeriodLabels() {
  const {year, month} = getSchedulePeriod();
  const label = `${year}年${month+1}月`;
  ['scheduleperiodLabel','summaryPeriodLabel'].forEach(id => {
    const el = document.getElementById(id);
    if(el) el.textContent = label;
  });
}

function updateBadges() {
  const b = storeBadgeHTML();
  ['emp','shift','config','schedule','summary'].forEach(k => {
    const el = document.getElementById(k + 'StoreBadge');
    if(el) el.outerHTML = `<span class="topbar-store-badge" id="${k}StoreBadge">${b}</span>`;
  });
}

// ════════════════════════════════════════
//  STORE SWITCHER
// ════════════════════════════════════════
function renderStoreSwitcher() {
  const st = currentStore();
  document.getElementById('currentStoreDot').style.background = st.color;
  document.getElementById('currentStoreName').textContent = st.name;
  const list = document.getElementById('storeOptionList');
  list.innerHTML = stores.map(s => `
    <div class="store-option${s.id === currentStoreId ? ' active' : ''}" onclick="switchStore(${s.id})">
      <div class="store-dot" style="background:${s.color};"></div>
      <span>${s.name}</span>
      ${s.id === currentStoreId ? '<span style="font-size:10px;color:#6EE7A0;">✓</span>' : ''}
    </div>`).join('');
}

function toggleStoreDropdown() {
  document.getElementById('storeDropdown').classList.toggle('open');
}

function switchStore(id) {
  currentStoreId = id;
  if(!schedules[id]) schedules[id] = {};
  renderStoreSwitcher();
  document.getElementById('storeDropdown').classList.remove('open');
  // Re-render current active screen
  const active = document.querySelector('.screen.active');
  if(active) {
    const name = active.id.replace('screen-','');
    showScreen(name);
  }
}

// ════════════════════════════════════════
//  STORES SCREEN
// ════════════════════════════════════════
function renderStores() {
  const grid = document.getElementById('storeGrid');
  grid.innerHTML = stores.map(st => {
    const emps = employees.filter(e => e.storeId === st.id).length;
    const sh = shifts.filter(s => s.storeId === st.id && s.active).length;
    return `
    <div class="store-card">
      <div class="store-card-header">
        <div class="store-color-dot" style="background:${st.color};"></div>
        <div class="store-card-name">${st.name}</div>
      </div>
      <div style="font-size:11px;color:var(--text2);margin-bottom:10px;">${st.address || '未設定地址'}</div>
      <div class="store-card-stats">
        <div class="store-stat"><div class="store-stat-label">員工人數</div><div class="store-stat-value">${emps} 人</div></div>
        <div class="store-stat"><div class="store-stat-label">啟用班別</div><div class="store-stat-value">${sh} 種</div></div>
      </div>
      <div class="store-card-footer">
        <button class="btn btn-ghost btn-sm" onclick="switchStore(${st.id});showScreen('employees')">進入管理</button>
        <button class="btn btn-ghost btn-sm" onclick="openEditStoreModal(${st.id})">編輯</button>
        ${stores.length > 1 ? `<button class="btn btn-danger-ghost btn-sm" onclick="deleteStore(${st.id})">刪除</button>` : ''}
      </div>
    </div>`;
  }).join('') + `
    <div class="store-card" style="border:1.5px dashed var(--border);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;min-height:140px;" onclick="openAddStoreModal()">
      <div style="text-align:center;color:var(--text2);"><div style="font-size:24px;margin-bottom:6px;">＋</div><div style="font-size:12px;">新增分店</div></div>
    </div>`;
}

let editingStoreId = null;
let selectedColor = STORE_COLORS[0];

function openAddStoreModal() {
  editingStoreId = null;
  selectedColor = STORE_COLORS.find(c => !stores.find(s => s.color === c)) || STORE_COLORS[0];
  document.getElementById('storeModalTitle').textContent = '新增分店';
  document.getElementById('storeName').value = '';
  document.getElementById('storeAddress').value = '';
  renderColorPicker();
  document.getElementById('storeDropdown').classList.remove('open');
  document.getElementById('storeModal').classList.add('open');
}

function openEditStoreModal(id) {
  editingStoreId = id;
  const st = stores.find(s => s.id === id);
  selectedColor = st.color;
  document.getElementById('storeModalTitle').textContent = '編輯分店';
  document.getElementById('storeName').value = st.name;
  document.getElementById('storeAddress').value = st.address || '';
  renderColorPicker();
  document.getElementById('storeModal').classList.add('open');
}

function renderColorPicker() {
  document.getElementById('colorPicker').innerHTML = STORE_COLORS.map(c =>
    `<div class="color-swatch${c === selectedColor ? ' selected' : ''}" style="background:${c};" onclick="selectColor('${c}')"></div>`
  ).join('');
}

function selectColor(c) { selectedColor = c; renderColorPicker(); }

function saveStore() {
  const name = document.getElementById('storeName').value.trim();
  if(!name) { alert('請輸入店名'); return; }
  if(editingStoreId) {
    const st = stores.find(s => s.id === editingStoreId);
    st.name = name; st.address = document.getElementById('storeAddress').value.trim(); st.color = selectedColor;
  } else {
    const newId = sid();
    stores.push({ id: newId, name, address: document.getElementById('storeAddress').value.trim(), color: selectedColor });
    shifts.push(...makeDefaultShifts(newId));
    schedules[newId] = {};
  }
  closeModal('storeModal');
  renderStoreSwitcher();
  renderStores();
}

function deleteStore(id) {
  if(!confirm('確定要刪除此分店？相關員工和班表資料也會一併刪除。')) return;
  stores = stores.filter(s => s.id !== id);
  employees = employees.filter(e => e.storeId !== id);
  shifts = shifts.filter(s => s.storeId !== id);
  delete schedules[id];
  if(currentStoreId === id) { currentStoreId = stores[0]?.id || null; }
  renderStoreSwitcher();
  renderStores();
}

// ════════════════════════════════════════
//  EMPLOYEES
// ════════════════════════════════════════
function renderEmployees() {
  const grid = document.getElementById('empGrid');
  const emps = storeEmps();
  const prefLabel = { m:'早班', a:'午班', e:'晚班' };
  const prefTag   = { m:'tag-morning', a:'tag-afternoon', e:'tag-evening' };
  grid.innerHTML = emps.map(e => `
    <div class="emp-card">
      <div class="emp-avatar" style="background:${e.avatarBg};color:${e.avatarColor};">${e.name[0]}</div>
      <div class="emp-name">${e.name}</div>
      <div class="emp-rate">NT$ ${e.rate} / hr</div>
      <div class="tag-row">
        ${e.prefs.map(p => `<span class="tag ${prefTag[p]}">${prefLabel[p]}</span>`).join('')}
        ${e.minSalaryOn ? `<span class="tag tag-minsalary">最低薪資 ✓</span>` : ''}
      </div>
      <div style="font-size:11px;color:var(--text2);">${e.unavail.length ? '不可排班：' + e.unavail.map(d=>d.slice(5).replace('-','/')).join(', ') : '無限制'}</div>
      <div class="emp-card-footer"><button class="btn btn-ghost btn-sm" onclick="openEditEmpModal(${e.id})">編輯</button></div>
    </div>`).join('') + `
    <div class="emp-card" style="border:1.5px dashed var(--border);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;min-height:140px;" onclick="openAddEmpModal()">
      <div style="text-align:center;color:var(--text2);"><div style="font-size:24px;margin-bottom:6px;">＋</div><div style="font-size:12px;">新增員工</div></div>
    </div>`;
}

let editingEmpId = null;
function openAddEmpModal() {
  editingEmpId = null;
  document.getElementById('empModalTitle').textContent = '新增員工';
  document.getElementById('empName').value = '';
  document.getElementById('empRate').value = '';
  document.getElementById('empMinSalary').value = '';
  ['m','a','e'].forEach(p => document.getElementById('pref-'+p).className = 'pref-btn');
  document.getElementById('minSalaryToggle').className = 'toggle off';
  document.getElementById('minSalaryRow').style.display = 'none';
  document.getElementById('empModal').classList.add('open');
}
function openEditEmpModal(id) {
  editingEmpId = id;
  const e = employees.find(x => x.id === id);
  document.getElementById('empModalTitle').textContent = '編輯員工 — ' + e.name;
  document.getElementById('empName').value = e.name;
  document.getElementById('empRate').value = e.rate;
  document.getElementById('empMinSalary').value = e.minSalary || '';
  ['m','a','e'].forEach(p => {
    const btn = document.getElementById('pref-'+p);
    const sel = {m:'sel-m',a:'sel-a',e:'sel-e'};
    btn.className = 'pref-btn' + (e.prefs.includes(p) ? ' '+sel[p] : '');
  });
  document.getElementById('minSalaryToggle').className = 'toggle ' + (e.minSalaryOn ? 'on' : 'off');
  document.getElementById('minSalaryRow').style.display = e.minSalaryOn ? 'block' : 'none';
  document.getElementById('empModal').classList.add('open');
}
function saveEmployee() {
  const name = document.getElementById('empName').value.trim();
  const rate = parseInt(document.getElementById('empRate').value) || 0;
  const prefs = ['m','a','e'].filter(p => document.getElementById('pref-'+p).className.includes('sel-'));
  const minOn = document.getElementById('minSalaryToggle').classList.contains('on');
  const minSal = parseInt(document.getElementById('empMinSalary').value) || 0;
  if(!name || !rate) { alert('請填寫姓名與時薪'); return; }
  if(editingEmpId) {
    const e = employees.find(x => x.id === editingEmpId);
    Object.assign(e, { name, rate, prefs, minSalaryOn:minOn, minSalary:minSal });
  } else {
    const pal = AVATAR_PALETTES[employees.filter(e=>e.storeId===currentStoreId).length % AVATAR_PALETTES.length];
    employees.push({ id:sid(), storeId:currentStoreId, name, rate, prefs, minSalaryOn:minOn, minSalary:minSal, unavail:[], avatarBg:pal[0], avatarColor:pal[1] });
  }
  closeModal('empModal');
  renderEmployees();
}
function togglePref(p) {
  const btn = document.getElementById('pref-'+p);
  const sel = {m:'sel-m',a:'sel-a',e:'sel-e'};
  btn.classList.toggle(sel[p]);
}
function toggleMinSalary() {
  const t = document.getElementById('minSalaryToggle');
  t.classList.toggle('on'); t.classList.toggle('off');
  document.getElementById('minSalaryRow').style.display = t.classList.contains('on') ? 'block' : 'none';
}

