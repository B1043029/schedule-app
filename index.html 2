let editingUnavailEmpId=null, calYear=2025, calMonth=6, tempUnavail=new Set();
function openUnavailModal(empId) {
  editingUnavailEmpId=empId;
  const e=employees.find(x=>x.id===empId);
  tempUnavail=new Set(e.unavail); const _p=getSchedulePeriod(); calYear=_p.year; calMonth=_p.month;
  document.getElementById('unavailModalTitle').textContent=`${e.name} — 不可排班日`;
  renderCal(); document.getElementById('unavailModal').classList.add('open');
}
function renderCal() {
  const months=['一月','二月','三月','四月','五月','六月','七月','八月','九月','十月','十一月','十二月'];
  document.getElementById('calMonthLabel').textContent=`${calYear}年 ${months[calMonth]}`;
  document.getElementById('calDayLabels').innerHTML=['日','一','二','三','四','五','六'].map(d=>`<div class="cal-day-label">${d}</div>`).join('');
  const first=new Date(calYear,calMonth,1).getDay(), days=new Date(calYear,calMonth+1,0).getDate();
  let html='';
  for(let i=0;i<first;i++) html+='<div class="cal-day empty"></div>';
  for(let d=1;d<=days;d++){
    const ds=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    html+=`<div class="cal-day${tempUnavail.has(ds)?' blocked':''}" onclick="toggleDay('${ds}')">${d}</div>`;
  }
  document.getElementById('calGrid').innerHTML=html;
  document.getElementById('calSelected').textContent=[...tempUnavail].sort().map(d=>d.slice(5).replace('-','/')).join(', ')||'無';
}
function toggleDay(d){if(tempUnavail.has(d))tempUnavail.delete(d);else tempUnavail.add(d);renderCal();}
function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCal();}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCal();}
function saveUnavail(){
  const e=employees.find(x=>x.id===editingUnavailEmpId);
  if(e)e.unavail=[...tempUnavail].sort();
  closeModal('unavailModal'); renderUnavailList();
}

// ════════════════════════════════════════
//  AUTO SCHEDULE
// ════════════════════════════════════════
function runAutoSchedule() {
  const btn = document.getElementById('rerunBtn');
  if(btn){btn.innerHTML='<span class="spinning">⏳</span> 排班中...';btn.disabled=true;}
  setTimeout(()=>{
    generateSchedule();
    if(btn){btn.innerHTML='🔄 重新自動排班';btn.disabled=false;}
    showScreen('schedule');
  }, 900);
}
function getSchedulePeriod() {
  const startEl = document.getElementById('configStartDate');
  const val = startEl ? startEl.value.trim() : '';
  // Accept YYYY/MM/DD or YYYY-MM-DD
  const parts = val.replace(/-/g,'/').split('/');
  if(parts.length === 3 && !isNaN(parts[0]) && !isNaN(parts[1])) {
    return { year: parseInt(parts[0]), month: parseInt(parts[1]) - 1 };
  }
  // fallback to current month
  const now = new Date();
  return { year: now.getFullYear(), month: now.getMonth() };
}

function generateSchedule() {
  schedules[currentStoreId] = {};
  const sch = schedules[currentStoreId];
  const {year, month} = getSchedulePeriod();
  const days = new Date(year, month+1, 0).getDate();
  const activeShifts = storeShifts().filter(s=>s.active);
  const emps = storeEmps();
  const consecutive={}; emps.forEach(e=>consecutive[e.id]=0);
  for(let d=1;d<=days;d++){
    const ds=`${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow=new Date(year,month,d).getDay();
    const hols=getHolidays(year,month);
    const isHol=isHoliday(ds,hols), isWknd=dow===0||dow===6;
    sch[ds]=[];
    const dayShifts=activeShifts.filter(s=>isHol?s.type==='holiday':isWknd?s.type==='weekend':s.type==='weekday');
    dayShifts.forEach(shift=>{
      const avail=emps.filter(e=>!e.unavail.includes(ds)&&consecutive[e.id]<6);
      const pref=avail.filter(e=>e.prefs.includes(shift.period));
      const pool=pref.length?pref:avail;
      [...pool].sort(()=>Math.random()-.5).slice(0,shift.staff).forEach(e=>{
        sch[ds].push({shiftId:shift.id,empId:e.id,locked:false});
        consecutive[e.id]++;
      });
    });
    emps.forEach(e=>{if(!sch[ds].some(a=>a.empId===e.id))consecutive[e.id]=0;});
  }
}

// ════════════════════════════════════════
//  SCHEDULE TABLE  (Y=班別, X=日期)
// ════════════════════════════════════════
function renderSchedule() {
  const {year, month} = getSchedulePeriod();
  const days = new Date(year, month+1, 0).getDate();
  const showDays=days; // show full month
  const table=document.getElementById('scheduleTable');
  const sch=storeSchedule();
  const activeShifts=storeShifts().filter(s=>s.active);
  const rowBg={morning:'#FFFBEB',afternoon:'#EFF6FF',evening:'#F5F3FF',holiday:'#FEF2F2'};

  // Header
  let hdr='<thead><tr><th style="min-width:100px;text-align:left;padding-left:10px;background:var(--surface2);">班別</th>';
  for(let d=1;d<=showDays;d++){
    const ds=`${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow=new Date(year,month,d).getDay();
    const dl=['日','一','二','三','四','五','六'][dow];
    const _hols=getHolidays(year,month);
    const isHol=isHoliday(ds,_hols),isWknd=dow===0||dow===6,red=isHol||isWknd;
    hdr+=`<th style="min-width:68px;${isHol?'background:#FEF2F2;':''}">
      <div style="font-size:10px;color:${red?'var(--accent2)':'var(--text2)'};">週${dl}</div>
      <div class="date-num${red?' date-red':''}">${month+1}/${d}</div>
      ${isHol?'<div style="color:var(--accent2);font-size:9px;font-weight:600;">國定</div>':''}
    </th>`;
  }
  

  // Body
  let body='<tbody>';
  activeShifts.forEach(shift=>{
    const rb=rowBg[shift.period]||'#fff';
    body+=`<tr><td style="background:var(--surface2);font-weight:600;padding:7px 10px;white-space:nowrap;border:1px solid var(--border);">
      <span class="shift-dot ${dotClass[shift.period]||'dot-morning'}"></span>${shift.name}
      <div style="font-family:var(--mono);font-size:10px;color:var(--text2);font-weight:400;">${shift.start}–${shift.end}</div>
    </td>`;
    for(let d=1;d<=showDays;d++){
      const ds=`${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const dow=new Date(year,month,d).getDay();
      const isHol=isHoliday(ds,getHolidays(year,month)),isWknd=dow===0||dow===6;
      const applies=isHol?shift.type==='holiday':isWknd?shift.type==='weekend':shift.type==='weekday';
      if(!applies){body+=`<td style="background:#F7F7F5;text-align:center;border:1px solid var(--border);"><span style="color:#D0CBC4;font-size:10px;">—</span></td>`;continue;}
      const assigned=(sch[ds]||[]).filter(a=>a.shiftId===shift.id);
      const needed=shift.staff, lacking=assigned.length<needed;
      const cellBg=isHol?'#FEF2F2':rb;
      const cc=isHol?'cell-holiday':cellClass[shift.period]||'cell-morning';
      if(assigned.length===0){
        body+=`<td style="background:${lacking?'#FFF3F3':cellBg};text-align:center;vertical-align:middle;cursor:pointer;border:1px solid var(--border);" onclick="openAssignModal('${ds}',${shift.id})">
          <span style="color:${lacking?'var(--accent2)':'#C8C3BB'};font-size:11px;">${lacking?'⚠️ 缺':'＋'}</span></td>`;
      } else {
        const chips=assigned.map(a=>{
          const emp=storeEmps().find(e=>e.id===a.empId); if(!emp) return '';
          return `<div style="display:flex;align-items:center;justify-content:center;gap:2px;margin:2px 1px;">
            <span class="emp-name-chip ${cc}${a.locked?' cell-locked':''}" onclick="toggleLock('${ds}',${a.empId},${a.shiftId})">${emp.name}${a.locked?' 🔒':''}</span>
            <span class="remove-btn" onclick="removeAssign('${ds}',${a.empId},${a.shiftId})">✕</span>
          </div>`;
        }).join('');
        const warn=lacking?`<div style="font-size:9px;color:var(--accent2);margin-top:1px;">需再補${needed-assigned.length}人</div>`:'';
        const add=`<div class="add-emp-btn" onclick="openAssignModal('${ds}',${shift.id})">＋ 加人</div>`;
        body+=`<td style="background:${cellBg};text-align:center;vertical-align:middle;padding:3px;border:1px solid var(--border);">${chips}${warn}${add}</td>`;
      }
    }
    body+='</tr>';
  });
  body+='</tbody>';
  table.innerHTML=hdr+body;
}

function toggleLock(ds,empId,shiftId){
  const sch=storeSchedule();
  const a=(sch[ds]||[]).find(x=>x.empId===empId&&x.shiftId===shiftId);
  if(a){a.locked=!a.locked;renderSchedule();}
}

// ════════════════════════════════════════
//  MANUAL ASSIGN / REMOVE
// ════════════════════════════════════════
let assignContext={dateStr:null,shiftId:null};
function openAssignModal(ds,shiftId){
  assignContext={dateStr:ds,shiftId};
  const shift=shifts.find(s=>s.id===shiftId);
  const dow=new Date(ds).getDay();
  document.getElementById('assignModalSubtitle').textContent=
    `${ds.slice(5).replace('-','/')}（週${'日一二三四五六'[dow]}）· ${shift?shift.name:''}`;
  const sch=storeSchedule();
  const already=(sch[ds]||[]).filter(a=>a.shiftId===shiftId).map(a=>a.empId);
  document.getElementById('assignEmpList').innerHTML=storeEmps().map(emp=>{
    const isAlready=already.includes(emp.id);
    const isUnavail=emp.unavail.includes(ds);
    let cls='',lbl='',click=true;
    if(isAlready){cls='already';lbl='<span style="font-size:10px;">已排班</span>';click=false;}
    else if(isUnavail){cls='unavail';lbl='<span style="font-size:10px;">不可排班日</span>';click=false;}
    else{lbl='<span style="font-size:10px;color:var(--accent);">點擊指派</span>';}
    return `<div class="assign-emp-row ${cls}" ${click?`onclick="assignEmp('${ds}',${shiftId},${emp.id})"`:''}>
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:50%;background:${emp.avatarBg};color:${emp.avatarColor};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;">${emp.name[0]}</div>
        <div><div style="font-weight:600;font-size:13px;">${emp.name}</div>
        <div style="font-size:11px;color:var(--text2);font-family:var(--mono);">NT$${emp.rate}/hr · 偏好${{m:'早',a:'午',e:'晚'}[emp.prefs[0]]||'—'}</div></div>
      </div>${lbl}</div>`;
  }).join('');
  document.getElementById('assignModal').classList.add('open');
}
function assignEmp(ds,shiftId,empId){
  const sch=storeSchedule();
  if(!sch[ds])sch[ds]=[];
  if(!sch[ds].find(a=>a.shiftId===shiftId&&a.empId===empId))
    sch[ds].push({shiftId,empId,locked:false});
  closeModal('assignModal'); renderSchedule();
}
function removeAssign(ds,empId,shiftId){
  const sch=storeSchedule();
  if(!sch[ds])return;
  sch[ds]=sch[ds].filter(a=>!(a.empId===empId&&a.shiftId===shiftId));
  renderSchedule();
}

// ════════════════════════════════════════
//  SUMMARY
// ════════════════════════════════════════
function renderSummary(){
  const sch=storeSchedule(), emps=storeEmps();
  let totalS=0,totalH=0,totalW=0,warnN=0;
  const rows=emps.map(emp=>{
    let nH=0,hH=0,sc=0;
    Object.entries(sch).forEach(([ds,asgns])=>{
      asgns.filter(a=>a.empId===emp.id).forEach(a=>{
        const s=shifts.find(x=>x.id===a.shiftId);if(!s)return;
        const h=shiftHours(s);
        const {year:sy,month:sm}=getSchedulePeriod();
        if(isHoliday(ds,getHolidays(sy,sm))||s.mult>1)hH+=h;else nH+=h;
        sc++;
      });
    });
    const sal=Math.round(nH*emp.rate+hH*emp.rate*2);
    const ok=!emp.minSalaryOn||sal>=emp.minSalary;
    if(!ok)warnN++;
    totalS+=sc;totalH+=nH+hH;totalW+=sal;
    return{emp,sc,nH,hH,sal,ok};
  });
  document.getElementById('summaryCards').innerHTML=[
    ['總班數',totalS,''],['總工時',totalH.toFixed(0)+'h',''],
    ['薪資總計','NT$'+totalW.toLocaleString(),''],
    ['未達最低薪資',warnN+' 人',warnN>0?'color:var(--warn)':''],
  ].map(([l,v,s])=>`<div class="card" style="margin-bottom:0;text-align:center;"><div style="font-size:11px;color:var(--text2);margin-bottom:4px;">${l}</div><div style="font-size:22px;font-family:var(--mono);font-weight:700;${s}">${v}</div></div>`).join('');
  document.getElementById('summaryWarn').innerHTML=rows.filter(r=>!r.ok).map(r=>
    `<div class="warn-banner">⚠️ <span><strong>${r.emp.name}</strong> 預估 NT$${r.sal.toLocaleString()}，低於門檻 NT$${r.emp.minSalary.toLocaleString()}</span></div>`).join('');
  document.getElementById('summaryBody').innerHTML=rows.map(r=>`
    <tr><td><strong>${r.emp.name}</strong></td><td>${r.sc}</td><td>${r.nH.toFixed(0)}h</td><td>${r.hH.toFixed(0)}h</td>
    <td>${(r.nH+r.hH).toFixed(0)}h</td><td class="salary-num">NT$${r.sal.toLocaleString()}</td>
    <td class="salary-num" style="color:${r.emp.minSalaryOn?'var(--accent2)':'var(--text2)'};">${r.emp.minSalaryOn?'NT$'+r.emp.minSalary.toLocaleString():'—'}</td>
    <td><span class="status-badge ${r.ok?'status-ok':'status-warn'}">${r.ok?'達標 ✓':'未達標 ⚠️'}</span></td></tr>`).join('');
}

